# Postgres (povinné v produkcii; lokálne default postgres://postgres:devpass@localhost:5433/grantexpert)
DATABASE_URL=postgres://user:password@host:5432/grantexpert

# Ak DB vyžaduje TLS (napr. Neon, Supabase, DigitalOcean), nastav na 1
DATABASE_SSL=1

# Session secret — v produkcii nastav vlastný náhodný reťazec
SESSION_SECRET=zmen-ma-na-nahodny-retazec

# Externé SMTP pre magic linky a notifikácie objednávok.
# Ak SMTP_HOST nie je nastavený, magic link sa vypíše do konzoly (len na vývoj).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=noreply@example.com
SMTP_PASS=heslo
MAIL_FROM="GrantExpert <noreply@example.com>"

# E-mail, kam chodia notifikácie o objednávkach služieb (voliteľné)
ORDERS_EMAIL=

# Admin zóna (/admin) — čiarkou oddelené e-maily správcov
ADMIN_EMAILS=filip@ques.sk

# Tajomstvo pre /cron/* endpointy (ingest výziev z ITMS, radar digest).
# Na Cloudflare: wrangler secret put CRON_SECRET; joby spúšťa Worker (Cron Triggers každých 6 h).
# Mimo Cloudflare nastav ENABLE_INTERNAL_CRON=1 a joby beží priamo v aplikácii.
CRON_SECRET=
ENABLE_INTERNAL_CRON=0

# Verejná URL webu (používa sa v magic linkoch a radar e-mailoch)
BASE_URL=http://localhost:3000

# DEV_MODE=1 zobrazí magic link priamo na stránke (nikdy nezapínaj v produkcii)
DEV_MODE=0

PORT=3000

# TED ingest tendrov (voliteľné ladenie)
TENDER_MAX_PAGES=10
TENDER_PAGE_SIZE=100
