<%- include('partials/head') %>
<%- include('partials/header') %>

<div class="container">
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="alert alert-success" role="alert">
        <strong>Odkaz odoslaný.</strong> Skontrolujte si schránku <%= email %>.
      </div>
      <p>Poslali sme vám prihlasovací odkaz. Platí 15 minút a dá sa použiť len raz. Ak e-mail nevidíte, pozrite si priečinok nevyžiadanej pošty.</p>

      <% if (devLink) { %>
        <div class="notification-banner">
          <div class="nb-head">Núdzový režim (SMTP nie je nastavené)</div>
          <div class="nb-body">
            <p>Odkaz na prihlásenie: <a href="<%= devLink %>">prihlásiť sa teraz</a></p>
          </div>
        </div>
      <% } %>

      <a class="btn btn-ghost" href="/">Späť na titulku</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
