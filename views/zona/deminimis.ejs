<%- include('../partials/head') %>
<%- include('../partials/header') %>
<div class="container zone">
  <%- include('menu', { active: 'deminimis' }) %>
  <div>
    <h1 style="font-size:1.7rem">De minimis kalkulačka</h1>
    <p class="muted">Pomoc malého rozsahu podľa nariadenia (EÚ) 2023/2831: limit <strong>300 000 €</strong> pre jediný podnik za ľubovoľné 3 kĺzavé roky. Evidujte každú prijatú minimálnu pomoc (dotácie, vouchery, zvýhodnené úvery) vrátane prepojených firiem.</p>

    <% if (savedMsg) { %><div class="alert alert-success" role="alert"><strong>Uložené.</strong></div><% } %>
    <% if (refreshing) { %>
      <div class="alert alert-info" role="alert">
        <strong>Načítavame vašu pomoc z registra IS SEMP…</strong> pre IČO <span class="mono"><%= ico %></span>.
        Obnovte stránku o pár sekúnd — dáta sa dopĺňajú na pozadí, aby web ostal rýchly.
      </div>
    <% } %>

    <div class="kpis" style="grid-template-columns:repeat(3,1fr);margin-bottom:1.3rem">
      <div class="kpi"><div class="num"><%= drawn.toLocaleString('sk-SK', {maximumFractionDigits: 0}) %> €</div><div class="lbl">čerpané v 3-ročnom okne (od <%= fmtDate(cutoff) %>)</div></div>
      <div class="kpi" style="border-top-color:<%= remaining > 50000 ? 'var(--success)' : 'var(--error)' %>"><div class="num"><%= remaining.toLocaleString('sk-SK', {maximumFractionDigits: 0}) %> €</div><div class="lbl">zostávajúci priestor do limitu</div></div>
      <div class="kpi"><div class="num"><%= Math.round(drawn / limit * 100) %> %</div><div class="lbl">vyčerpané z 300 000 €</div></div>
    </div>
    <% if (remaining < 50000) { %>
      <div class="alert alert-error" role="alert"><strong>Pozor:</strong> blížite sa k stropu de minimis. Pomoc nad limit sa vracia aj s úrokmi — pred podaním žiadosti si overte presný stav.</div>
    <% } %>

    <% if (ico) { %>
      <div class="alert alert-info" role="alert" style="margin-bottom:1.3rem">
        <strong>Automaticky z registra IS SEMP:</strong> pre IČO <span class="mono"><%= ico %></span> evidujeme <strong><%= registryCount %></strong> záznamov prijatej minimálnej pomoci. Register aktualizujeme raz týždenne. Zmeniť IČO môžete v <a href="/ucet">profile</a>.
      </div>
    <% } else { %>
      <div class="alert alert-info" role="alert" style="margin-bottom:1.3rem">
        Zadajte IČO svojej firmy v <a href="/ucet">profile účtu</a> — automaticky sem načítame vaše čerpanie de minimis z oficiálneho registra, bez hľadania.
      </div>
    <% } %>

    <% if (!aids.length) { %>
      <div class="empty"><h3>Žiadne záznamy pre toto IČO</h3><p><% if (ico) { %>V centrálnom registri IS SEMP zatiaľ pre IČO <span class="mono"><%= ico %></span> neevidujeme žiadnu minimálnu pomoc. Register aktualizujeme raz týždenne.<% } else { %>Zadajte IČO svojej firmy v <a href="/ucet">profile</a> a automaticky sem načítame vaše čerpanie z registra.<% } %></p></div>
    <% } else { %>
      <table class="t t--cards">
        <thead><tr><th>Dátum</th><th>Poskytovateľ</th><th>Suma</th><th>V okne</th></tr></thead>
        <tbody>
          <% for (const a of aids) { const inW = new Date(a.granted_at) >= cutoff;
             const scheme = (a.scheme_code || '').match(/\d{3,4}\/\d{4}/) ? 'de minimis ' + a.scheme_code.match(/\d{3,4}\/\d{4}/)[0] : (a.note || ''); %>
            <tr>
              <td data-label="Dátum" class="nowrap"><%= fmtDate(a.granted_at) %></td>
              <td data-label="Poskytovateľ"><%= a.provider %>
                <br><span class="small muted"><%= scheme %><% if (a.source === 'manual') { %> · ručne<% } %></span></td>
              <td data-label="Suma"><strong><%= Number(a.amount_eur).toLocaleString('sk-SK') %> €</strong></td>
              <td data-label="V okne"><span class="badge-stage <%= inW ? 's-preparing' : 's-won' %>"><%= inW ? 'počíta sa' : 'mimo okna' %></span>
                <% if (a.source === 'manual') { %><form method="post" action="/ucet/deminimis/<%= a.id %>/zmazat" data-confirm="Zmazať záznam?" style="display:inline;margin-left:.4rem"><button class="btn btn-danger btn-sm">Zmazať</button></form><% } %></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    <% } %>
    <p class="small muted">Kalkulačka je orientačná pomôcka, nie právne záväzný výpočet — rozhodujúca je evidencia v IS SEMP a čestné vyhlásenie. Limit platí za „jediný podnik“ (prepojené firmy spolu); pre cestnú nákladnú dopravu platia osobitné pravidlá.</p>
  </div>
</div>
<%- include('../partials/footer') %>
