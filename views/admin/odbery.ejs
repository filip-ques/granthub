<%- include('../partials/head') %>
<%- include('../partials/header') %>

<div class="container zone" style="grid-template-columns:250px 1fr">
  <%- include('partials/menu', { active: 'odbery' }) %>

  <div>
    <h1 style="font-size:1.7rem">Radar odbery</h1>
    <% if (!subs.length) { %>
      <div class="empty"><h3>Žiadne odbery</h3></div>
    <% } else { %>
      <table class="t t--cards">
        <thead><tr><th>E-mail</th><th>Oblasti</th><th>Od</th><th>Stav</th><th data-label=""></th></tr></thead>
        <tbody>
          <% for (const s of subs) { %>
            <tr>
              <td data-label="E-mail"><%= s.email %></td>
              <td data-label="Oblasti" class="small"><%= s.categories ? s.categories.split('|').join(', ') : 'všetky' %></td>
              <td data-label="Od" class="small"><%= fmtDate(s.created_at) %></td>
              <td data-label="Stav"><span class="badge-stage <%= s.confirmed ? 's-won' : 's-preparing' %>"><%= s.confirmed ? 'potvrdený' : 'čaká na potvrdenie' %></span></td>
              <td data-label="">
                <form method="post" action="/admin/odbery/<%= s.id %>/zmazat" data-confirm="Zmazať odber?"><button class="btn btn-danger btn-sm">Zmazať</button></form>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
