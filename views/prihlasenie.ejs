<%- include('partials/head') %>
<%- include('partials/header') %>

<div class="container">
  <div class="auth-wrap" style="max-width:<%= register ? "640px" : "460px" %>">
    <div class="auth-card">
      <h1 style="font-size:1.6rem"><%= register ? 'Registrácia' : 'Prihlásenie' %></h1>
      <p class="muted"><%= register
        ? 'Bez hesla a zadarmo. Zadajte e-mail, pošleme vám odkaz — kliknutím dokončíte registráciu a ste prihlásení.'
        : 'Bez hesla. Zadajte e-mail a pošleme vám prihlasovací odkaz — kliknutím naň ste prihlásení.' %></p>

      <% if (error) { %>
        <div class="error-summary" role="alert">
          <h2><%= register ? 'Registrácia sa nepodarila' : 'Prihlásenie sa nepodarilo' %></h2>
          <ul><li><%= error %></li></ul>
        </div>
      <% } %>

      <form method="post" action="/prihlasenie" novalidate>
        <input type="hidden" name="next" value="<%= next %>">
        <% if (register) { %><input type="hidden" name="register" value="1"><% } %>
        <div class="field">
          <label for="p-email">E-mail *</label>
          <input id="p-email" name="email" type="email" autocomplete="email" required autofocus>
        </div>
        <% if (register) { %>
          <fieldset style="border:0;padding:0;margin:0 0 1rem">
            <legend style="font-weight:700;font-size:.875rem;margin-bottom:.3rem">Aké granty vás zaujímajú?</legend>
            <div class="hint small muted" style="margin-bottom:.5rem">Nepovinné — podľa výberu vám budeme posielať relevantné výzvy.</div>
            <div class="checkbox-grid">
              <% CATEGORIES.slice(0, 8).forEach((c, i) => { %>
                <label style="display:flex;gap:.5rem;align-items:flex-start;font-weight:400">
                  <input type="checkbox" name="kategorie" value="<%= c %>" style="width:auto;margin-top:.2rem">
                  <span class="small"><%= c %></span>
                </label>
              <% }) %>
            </div>
          </fieldset>
          <fieldset style="border:0;padding:0;margin:0 0 1rem">
            <legend style="font-weight:700;font-size:.875rem;margin-bottom:.3rem">Aké tendre vás zaujímajú?</legend>
            <div class="checkbox-grid">
              <% INDUSTRIES.filter(i => i.key !== 'ostatne').slice(0, 8).forEach((ind) => { %>
                <label style="display:flex;gap:.5rem;align-items:flex-start;font-weight:400">
                  <input type="checkbox" name="odvetvia" value="<%= ind.key %>" style="width:auto;margin-top:.2rem">
                  <span class="small"><%= ind.label %></span>
                </label>
              <% }) %>
            </div>
          </fieldset>
        <% } %>
        <button type="submit" class="btn btn-primary btn-block"><%= register ? 'Zaregistrovať sa a dostávať relevantné ponuky' : 'Poslať prihlasovací odkaz' %></button>
      </form>

      <p class="small muted mt2 mb0"><%= register
        ? 'Registrácia = prvé prihlásenie. Získate ukladanie výziev, prehľad objednávok a správu grantového radaru.'
        : 'Prvým prihlásením si zároveň vytvoríte účet. Je to zadarmo.' %></p>
      <p class="small mt1 mb0"><% if (register) { %>Už máte účet? <a href="/prihlasenie">Prihláste sa</a>.<% } else { %>Nemáte účet? <a href="/registracia">Zaregistrujte sa</a> — stačí e-mail.<% } %></p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
